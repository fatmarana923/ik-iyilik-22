/*
# Chat rooms and messages for employee group chat

1. Overview
Adds group chat functionality so employees can communicate in department/topic-based rooms
(e.g., Finans, Sosyal Medya, Yöneticiler). Employees sign in with Supabase email/password
auth; messages are scoped to authenticated users only.

2. New Tables
- chat_rooms (id, name, description, icon, created_at) — group chat rooms
- chat_messages (id, room_id FK→chat_rooms, user_id DEFAULT auth.uid(), author_name,
  content, created_at) — messages in a room

3. Security
- chat_rooms: SELECT for authenticated (any logged-in employee can see room list);
  INSERT/UPDATE/DELETE restricted to authenticated (admin can manage rooms).
- chat_messages: SELECT for authenticated (any logged-in employee can read messages);
  INSERT for authenticated (author must be the logged-in user — enforced by
  DEFAULT auth.uid() on user_id + WITH CHECK auth.uid() = user_id);
  DELETE/UPDATE restricted to message owner.
*/

-- ---------- chat_rooms ----------
CREATE TABLE IF NOT EXISTS chat_rooms (
  id uuid PRIMARY KEY DEFAULT gen_random_uuid(),
  name text NOT NULL,
  description text,
  icon text DEFAULT 'message-circle',
  created_at timestamptz DEFAULT now()
);
ALTER TABLE chat_rooms ENABLE ROW LEVEL SECURITY;

DROP POLICY IF EXISTS "auth_select_chat_rooms" ON chat_rooms;
CREATE POLICY "auth_select_chat_rooms" ON chat_rooms FOR SELECT
  TO authenticated USING (true);
DROP POLICY IF EXISTS "auth_insert_chat_rooms" ON chat_rooms;
CREATE POLICY "auth_insert_chat_rooms" ON chat_rooms FOR INSERT
  TO authenticated WITH CHECK (true);
DROP POLICY IF EXISTS "auth_update_chat_rooms" ON chat_rooms;
CREATE POLICY "auth_update_chat_rooms" ON chat_rooms FOR UPDATE
  TO authenticated USING (true) WITH CHECK (true);
DROP POLICY IF EXISTS "auth_delete_chat_rooms" ON chat_rooms;
CREATE POLICY "auth_delete_chat_rooms" ON chat_rooms FOR DELETE
  TO authenticated USING (true);

-- ---------- chat_messages ----------
CREATE TABLE IF NOT EXISTS chat_messages (
  id uuid PRIMARY KEY DEFAULT gen_random_uuid(),
  room_id uuid NOT NULL REFERENCES chat_rooms(id) ON DELETE CASCADE,
  user_id uuid NOT NULL DEFAULT auth.uid() REFERENCES auth.users(id) ON DELETE CASCADE,
  author_name text NOT NULL,
  content text NOT NULL,
  created_at timestamptz DEFAULT now()
);
ALTER TABLE chat_messages ENABLE ROW LEVEL SECURITY;

DROP POLICY IF EXISTS "auth_select_chat_messages" ON chat_messages;
CREATE POLICY "auth_select_chat_messages" ON chat_messages FOR SELECT
  TO authenticated USING (true);
DROP POLICY IF EXISTS "auth_insert_chat_messages" ON chat_messages;
CREATE POLICY "auth_insert_chat_messages" ON chat_messages FOR INSERT
  TO authenticated WITH CHECK (auth.uid() = user_id);
DROP POLICY IF EXISTS "auth_update_own_chat_messages" ON chat_messages;
CREATE POLICY "auth_update_own_chat_messages" ON chat_messages FOR UPDATE
  TO authenticated USING (auth.uid() = user_id) WITH CHECK (auth.uid() = user_id);
DROP POLICY IF EXISTS "auth_delete_own_chat_messages" ON chat_messages;
CREATE POLICY "auth_delete_own_chat_messages" ON chat_messages FOR DELETE
  TO authenticated USING (auth.uid() = user_id);

CREATE INDEX IF NOT EXISTS idx_chat_messages_room ON chat_messages (room_id, created_at);
